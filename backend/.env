# Focus Room Backend 실제 환경 변수 (backend/.env.example 을 복사해 채운 파일)
# 이 파일은 .gitignore 로 제외되어 커밋되지 않습니다. 템플릿은 .env.example 참고.

PORT=4000

# MySQL 데이터베이스 설정
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=focus_room

# JWT 비밀키 — 충분히 길고 무작위한 값으로 설정하세요
JWT_SECRET=focus-room-secret-key
