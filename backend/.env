# Focus Room Backend 환경 변수 템플릿
# 이 파일(.env.example)은 추적되며, 복사해서 backend/.env 를 만들어 실제 값을 채우세요.
# 실제 .env 는 .gitignore 로 제외됩니다.
#   cp backend/.env.example backend/.env

PORT=4000

# MySQL 데이터베이스 설정
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=focus_room

# JWT 비밀키 — 충분히 길고 무작위한 값으로 설정하세요
JWT_SECRET=change-me-to-a-long-random-secret